# Solana Copy Trading Configuration

# Solana RPC Endpoint (For best results, use a private RPC with higher rate limits, e.g. Helius or QuickNode)
RPC_URL=https://api.mainnet-beta.solana.com

# Target Wallet Address to track and copy
TARGET_WALLET=3BLjRcxWGtR7WRshJ3hL25U3RjWr5Ud98wMcczQqk4Ei

# User Capital configurations
START_CAPITAL=1.0

# Copy Trade sizing boundaries (for risk-scaled strategy)
MIN_COPY_SIZE=0.05
MAX_COPY_SIZE=0.10

# Minimum SOL spent by target wallet in a BUY trade to copy it
# Set to 0.0 or 0.05 to copy all trades, or 0.9 to only copy larger entries.
MIN_TARGET_ENTRY_SIZE=0.90

